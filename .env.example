# Django core
SECRET_KEY=your-50-char-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Gemini AI — get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Redis — install Redis for Windows or use Redis Cloud free tier
# https://redis.io/docs/install/install-redis/install-redis-on-windows/
REDIS_URL=redis://localhost:6379/0

# CORS — Next.js frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Anonymous session TTL in hours (default 24)
SHADOW_SESSION_TTL_HOURS=24

# JaliBot rate limit: max messages per session per hour (default 30)
JALIBOT_RATE_LIMIT=30

# Production PostgreSQL (leave commented out for SQLite dev)
# DB_NAME=jalimind_db
# DB_USER=jalimind_user
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Email (for password reset etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@jalimind.org
